package day0318;

public class Ex12gogodan {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		int sum;
		for(int i=1;i<11;i++)
		{
			for(int j=1;j<11;j++)
			{
				sum = i * j;
				System.out.printf("%d * %d = %d",i,j,sum);
				if(i>=11)
				{
					System.out.println("잘못된숫자입니다.");
				}
			}
				
		}
	}

}
