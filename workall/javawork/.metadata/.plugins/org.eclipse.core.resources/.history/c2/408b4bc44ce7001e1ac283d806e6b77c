package day0321;

public class Ex9Study701 {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		String []members= {
				"강하윤","공병현","김도훈","김우형","김정호",
				"김창인","민경진","박민지","박보민","박주용",
				"박한경","배동우","서정현","손가원","시바타유니",
				"신완철","우태형","유상곤","이가현","이병현",
				"이장우","이현성","정민석","정상혁","정진욱",
				"정환용","최시현","허승필","황재웅","꽝"};
		String team[][] = new String[6][5];
		for(int i=0;i<team.length;i++)
		{
			for(int j=0;j<team[0].length;j++)
			{
				String n = String.valueOf(Math.random());
				team[i][j] = n;
				//중복처리
				for(int k=0;k<j;k++)
				{
					if(team[j]==team[k])
					{
						j--;
						break;//continue Loop;
					}
				}
			}
		}
		for(int i=0;i<team.length;i++)
		{
			for(int j=0;j<team[0].length;j++)
			{
				System.out.printf("[%d조 팀]\t%s\t%s\t%s\t%s\t%s",j+1,team[i][j]);
				System.out.println();
			}
		}
	}

}
