package day0318;

public class Ex9For {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		for(int i=0;i<10;i++)
		{
			System.out.println(i);
		}
		for(int i=0;i<10;i++)
		{
			System.out.println(i);
			if(i==5)
			{
				break;
			}
		}
		for(int i=0;i<10;i++)
		{
			if(i%2==0)
				continue;
			System.out.println(i);
		}
	}

}
