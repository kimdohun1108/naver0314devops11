package day0325;

public class Shop {
	private String sang;
	private int su;
	private int dan;
	
	public String getSang()
	{
		return sang;
	}
	public int getSu()
	{
		return su;
	}
	public int getDan()
	{
		return dan;
	}
	
	public void setSang(String sang)
	{
		this.sang = sang;
	}
	public void setSu(int su)
	{
		this.su = su;
	}
	public void setDan(int dan)
	{
		this.dan = dan;
	}
}
