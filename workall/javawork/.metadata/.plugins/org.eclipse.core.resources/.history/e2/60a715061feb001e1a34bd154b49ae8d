package day0326;

interface StudyInter
{
	public void javaStudy();
	public void springStudy();
}

interface PlayInter
{
	public void run();
	public void game();
}

class MyStudy implements StudyInter{
	@Override
	public void javaStudy() {
		// TODO Auto-generated method stub
		System.out.println("java study");
	}
	
	@Override
	public void springStudy() {
		// TODO Auto-generated method stub
		System.out.println("spring study");
	}
}

class MyPlay implements PlayInter{
	@Override
	public void run() {
		// TODO Auto-generated method stub
		System.out.println("run play");
	}
	
	@Override
	public void game() {
		// TODO Auto-generated method stub
		System.out.println("game play");
	}
}

public class EX7Interface {
	static public void study(StudyInter s)
	{
		s.javaStudy();
		s.springStudy();
	}
	
	static public void play(PlayInter p)
	{
		p.run();
		p.game();
	}
	
	public static void main(String[] args) {
		// TODO Auto-generated method stub
		study(new MyStudy());
		play(new MyPlay());
		
		
	}

}
