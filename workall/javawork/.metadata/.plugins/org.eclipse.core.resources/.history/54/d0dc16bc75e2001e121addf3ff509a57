package day0315;

public class Ex2DataType {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		//정수타입
		byte a = 127;
		System.out.println(a);
		
		//byte b = 200; <- 바이트 오류
		byte b = (byte) 200; // cast 연산자 : 강제 형변환 -> 값손실
		System.out.println(b);// 값손실이 발생할경우 값이 나오는데 (2의 보수값) 
		
		//실수타입
		float f1 = 123.567891234f; //f를 붙여야 4바이트 인식
		double f2 = 123.567891234;
		System.out.println(f1);// 보통 8자리까지 정확히 나옴
		System.out.println(f2);// 보통 15자리까지 정확히 나옴
		
		//문자타입
		char ch1 = 'A';
		char ch2 = '가'; // 2바이트여서 한글 가능
		System.out.println(ch1);
		System.out.println(ch2);
	}

}
