package day0318;

public class Ex10MultiFor {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		for(int i=0;i<10;i++)
		{
			System.out.println("Hello!");
			for(int j=1;j<10;j++)
			{
				System.out.println("Hello2!");
			}
			System.out.println();
		}
		System.out.println("--------------------");
		
		for(int i=0;i<5;i++)
		{
			for(int j=0;j<5;j++)
			{
				System.out.println("i= "+i+" j= "+j);
				if(j==2)
					break;
			}
			System.out.println();
		}
		System.out.println("---------------------");
	}

}
