package day0315;

public class Ex3DataType {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		int year = 2024;
		int month = 3;
		int day = 15;
		
		String msg = "Have a Nice Day!!";
		char blood = 'B';
		double avg = 97.4567;
		
		System.out.println("** 출력 1 **");
		System.out.println("날짜: "+year+"-"+month+"-"+day);
		System.out.print("혈액형 : "+blood+"형");
		System.out.println("\t평균 : "+avg);// \t : 탭 자동
		System.out.println("=============");
		/* 변환기호를 이용하여 출력
		 * 정수 %d, 실수 %f, 문자 %c, 문자열 %s
		 */
		System.out.printf("**%40s**\n\n",msg); // 우측기준
		System.out.printf("**%-40s**\n\n",msg); // 좌측기준
		System.out.printf("%s\n",msg);
	}

}
