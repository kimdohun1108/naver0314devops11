package day0320;

import java.util.Random;
import java.util.Scanner;

public class Ex3Randomgame {

	private static final String NULL = null;

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner sc = new Scanner(System.in); 
		Random r = new Random();
		int su, count = 0;
		String y = NULL;
		do {
			for(int i=0;i<count+1;i++)
			{
				int n = r.nextInt(10)+1;
				System.out.println("숫자 입력 : ");
				su = sc.nextInt();
				if(n==su)
				{
					count++;
					System.out.printf("정답! (숫자 : %d, 횟수 : %d)\n",su,count);
					break;
				}
				if(n!=su)
				{
					count++;
					System.out.println("오답 다시 하세요!");
					continue;
				}
			}

			System.out.println("게임을 다시 하시겠습니까? (y)");
			y = sc.nextLine();
			if(y=="y")
			{
				y = sc.next();
			}
			else
			{
				System.out.println("** 게임을 종료합니다 **");
				break;
			}
		}while (y.equals(y));

	}

}
