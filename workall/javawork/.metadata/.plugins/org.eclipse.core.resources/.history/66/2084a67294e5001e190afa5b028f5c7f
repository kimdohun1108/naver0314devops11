public class Ex1Munje {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		int count = 0;
		for(int i=1;i<101;i++)
		{
			for(int j=0;j<100;j++)
			{
				if(j/j!=0)
				{
					continue;
					System.out.printf("%d\n",i);
				}
			}
		}
		System.out.printf("실수는 %d개\n",count);
	}

}
