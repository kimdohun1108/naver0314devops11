package day0319;

public class Ex1Munje {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		//2,3,5,7
		int count = 100;
		for (int i=2;i<101;i++)
		{
			for(int j=2;j<i;j++)
			{
				if(i==j)
				{
					count--;
				}
				if(i!=j && i%j==0)
				{
					count--;
				}
			}
		}	
		System.out.printf("소수는 %d개\n",count);
	}
}
