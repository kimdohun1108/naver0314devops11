package day0319;

import java.util.Scanner;

public class Ex7whilemunje {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner sc = new Scanner(System.in);
		int score, count=0, sum=0;
		while(true)
		{
			score = sc.nextInt();
			if(score==0)
			{
				break;
			}
			sum += score;
			count++;
		}
	}

}
