public class Ex1Munje {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		//2,3,5,7
		int count = 0;
		for (int i = 2; i < 101; i++)
		{
			if(i%2!=0 || i%3!=0 || i%5!=0 || i%7!=0)
			{
				count++;
			}
		}	
		System.out.printf("소수는 %d개\n",count);
	}
}
